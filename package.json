{
  "name": "sitcord",
  "version": "0.1.2",
  "description": "Controller-first Electron mini-UI for joining and controlling Discord voice channels.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "keywords": [
    "discord",
    "voice",
    "gamepad",
    "controller",
    "electron",
    "overlay"
  ],
  "author": "LudoCogito",
  "homepage": "https://github.com/LudoCogito/sitcord",
  "repository": {
    "type": "git",
    "url": "https://github.com/LudoCogito/sitcord.git"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.dschwarz.sitcord",
    "productName": "Sitcord",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "LudoCogito",
      "repo": "sitcord"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
